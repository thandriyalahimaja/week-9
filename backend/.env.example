# Backend local environment template
PORT=3000
NODE_ENV=development
DB_URL=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-strong-secret
# For production, add your Vercel frontend origin here too.
CLIENT_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app